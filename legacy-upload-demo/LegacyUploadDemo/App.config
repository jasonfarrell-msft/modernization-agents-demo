<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="UploadDirectory" value="./uploads" />
    <add key="StorageConnectionString" value="DefaultEndpointsProtocol=https;AccountName=dummyuploads;AccountKey=REPLACE_WITH_REAL_KEY;EndpointSuffix=core.windows.net" />
    <add key="ApiKey" value="dummy-api-key-change-me" />
    <add key="SecretToken" value="dummy-secret-token-change-me" />
    <add key="SecurityNote" value="Modernize by moving secrets to Key Vault and using Managed Identity instead of config strings." />
  </appSettings>
  <connectionStrings>
    <add name="LegacyDb" connectionString="Server=tcp:demo-sql.database.windows.net,1433;Initial Catalog=LegacyUploadDemo;Persist Security Info=False;User ID=dummy-user;Password=ReplaceWithStrongPassword!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;" />
  </connectionStrings>
</configuration>
