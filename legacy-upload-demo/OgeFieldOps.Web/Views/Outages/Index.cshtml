@model OgeFieldOps.Web.Models.OutageListResult
@{
    ViewBag.Title = "Outages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Outage Work Orders</h2>

@using (Html.BeginForm("Index", "Outages", FormMethod.Get, new { @class = "form-inline", style = "margin-bottom:15px;" }))
{
    <div class="form-group">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search ticket, region, cause, status" style="width:340px;" />
    </div>
    <button type="submit" class="btn btn-default">Search</button>
    @Html.ActionLink("Clear", "Index", "Outages", null, new { @class = "btn btn-link" })
    @Html.ActionLink("New Work Order", "Create", "Outages", null, new { @class = "btn btn-primary pull-right", style = "margin-left:8px;" })
    @Html.ActionLink("Export CSV", "ExportCsv", "Outages", null, new { @class = "btn btn-success pull-right" })
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Ticket</th>
            <th>Region</th>
            <th>Cause</th>
            <th>Status</th>
            <th class="text-right">Customers</th>
            <th>Reported</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">No outages found.</td></tr>
        }
        @foreach (var o in Model.Items)
        {
            <tr>
                <td>@o.TicketNumber</td>
                <td>@o.Region</td>
                <td>@o.Cause</td>
                <td>
                    @{ var css = o.Status == "Restored" ? "label-success" : (o.Status == "In Progress" ? "label-warning" : "label-danger"); }
                    <span class="label @css">@o.Status</span>
                </td>
                <td class="text-right">@o.CustomersAffected.ToString("N0")</td>
                <td>@o.ReportedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @Html.ActionLink("Details", "Details", new { id = o.Id }, new { @class = "btn btn-xs btn-primary" })
                    @Html.ActionLink("Upload", "Upload", new { id = o.Id }, new { @class = "btn btn-xs btn-default" })
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="@(p == Model.Page ? "active" : "")">
                    @Html.ActionLink(p.ToString(), "Index", new { search = Model.Search, page = p })
                </li>
            }
        </ul>
    </nav>
}
<p class="text-muted">@Model.TotalCount outage(s) total.</p>
