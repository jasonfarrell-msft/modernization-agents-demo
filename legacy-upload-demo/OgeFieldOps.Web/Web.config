<?xml version="1.0" encoding="utf-8"?>
<!--
  OGE Field Operations & Outage Portal - legacy Web.config
  NOTE: This file is intentionally "dirty" for the modernization demo:
    - Connection string + secrets are stored here in plaintext (pre-cloud pattern).
    - File paths, SMTP pickup directory and feature flags come from appSettings.
  Modernization should move secrets to Key Vault and use Managed Identity.
-->
<configuration>
  <configSections>
    <sectionGroup name="system.web.webPages.razor" type="System.Web.WebPages.Razor.Configuration.RazorWebSectionGroup, System.Web.WebPages.Razor, Version=3.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35">
      <section name="host" type="System.Web.WebPages.Razor.Configuration.HostSection, System.Web.WebPages.Razor, Version=3.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" requirePermission="false" />
      <section name="pages" type="System.Web.WebPages.Razor.Configuration.RazorPagesSection, System.Web.WebPages.Razor, Version=3.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" requirePermission="false" />
    </sectionGroup>
  </configSections>

  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />

    <!-- ===== App-specific (intentionally legacy) settings ===== -->
    <!-- Server-local directory where uploaded field documents / meter files are written -->
    <add key="UploadDirectory" value="C:\OGE\FieldDocs" />
    <!-- Allowed upload extensions (comma separated) -->
    <add key="AllowedUploadExtensions" value=".pdf,.csv,.txt,.jpg,.jpeg,.png,.xlsx" />
    <!-- Max upload size in MB (also enforced by httpRuntime/requestLimits below) -->
    <add key="MaxUploadSizeMb" value="25" />
    <!-- Plain-text audit log file path -->
    <add key="AuditLogPath" value="C:\OGE\Logs\audit.log" />
    <!-- SMTP pickup directory: dispatch notifications are dropped here as .eml files -->
    <add key="NotificationPickupDirectory" value="C:\OGE\MailDrop" />
    <add key="NotificationFromAddress" value="fieldops-noreply@oge.com" />
    <add key="DispatchEmailAddress" value="dispatch@oge.com" />

    <!-- ===== Intentionally sensitive values in plaintext (modernization target) ===== -->
    <add key="IntegrationApiKey" value="oge-legacy-api-key-CHANGE-ME-1234567890" />
    <add key="MeterDataServicePassword" value="SuperSecretMeterPwd!2014" />
    <add key="SecurityNote" value="Modernize: move secrets to Key Vault and use Managed Identity instead of config." />
  </appSettings>

  <connectionStrings>
    <!-- On-prem SQL Server (SQL Server Express on the same VM) with credentials in plaintext -->
    <add name="OgeFieldOps"
         connectionString="Server=.\SQLEXPRESS;Database=OgeFieldOps;User ID=oge_app;Password=Oge#AppP@ss2014;MultipleActiveResultSets=False;Connection Timeout=30;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" maxRequestLength="25600" requestValidationMode="2.0" />

    <!-- Classic Forms Authentication (pre-cloud) -->
    <authentication mode="Forms">
      <forms loginUrl="~/Account/Login" timeout="60" name=".OGEFIELDOPSAUTH" slidingExpiration="true" protection="All" />
    </authentication>
    <authorization>
      <deny users="?" />
    </authorization>

    <sessionState mode="InProc" timeout="60" />

    <customErrors mode="Off" />

    <pages>
      <namespaces>
        <add namespace="System.Web.Mvc" />
        <add namespace="System.Web.Mvc.Ajax" />
        <add namespace="System.Web.Mvc.Html" />
        <add namespace="System.Web.Optimization" />
        <add namespace="System.Web.Routing" />
      </namespaces>
    </pages>
  </system.web>

  <system.net>
    <mailSettings>
      <!-- No real mail server: write .eml files to a pickup directory so dispatch
           notifications are demonstrable without external infrastructure. -->
      <smtp deliveryMethod="SpecifiedPickupDirectory" from="fieldops-noreply@oge.com">
        <specifiedPickupDirectory pickupDirectoryLocation="C:\OGE\MailDrop" />
      </smtp>
    </mailSettings>
  </system.net>

  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <modules runAllManagedModulesForAllRequests="true" />
    <security>
      <requestFiltering>
        <!-- 25 MB in bytes -->
        <requestLimits maxAllowedContentLength="26214400" />
      </requestFiltering>
    </security>
    <handlers>
      <!-- Ensure no inherited ASP.NET Core handler interferes with classic ASP.NET -->
      <remove name="aspNetCore" />
    </handlers>
  </system.webServer>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Mvc" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.9.0" newVersion="5.2.9.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Helpers" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.WebPages" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Optimization" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-1.1.0.0" newVersion="1.1.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="WebGrease" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-1.6.5135.21930" newVersion="1.6.5135.21930" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  <!-- Allow anonymous access to static assets so the login page renders styled. -->
  <location path="Content">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="Scripts">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="favicon.ico">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>
</configuration>
